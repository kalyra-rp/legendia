# Supabase project URL — found in your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon (public) key — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — server-only, NEVER expose to the browser
# Use only in server-side code (Route Handlers, Server Actions, RSC).
SUPABASE_SERVICE_ROLE_KEY=
